# Anthropic API key. If unset, the server falls back to the offline seed mystery
# (backend/src/seeds/khoon_ki_baraat.json) and template-based (non-AI) narration,
# so the app still runs end-to-end without a key.
ANTHROPIC_API_KEY=

# Anthropic model used by the Game Master. Defaults to a current Claude model if unset.
GM_MODEL=claude-sonnet-5

# Port the Express/Socket.io server listens on.
PORT=4000

# Origin of the Vite dev server / deployed frontend, used for CORS + Socket.io.
CLIENT_ORIGIN=http://localhost:5173

# Optional: directory to store the SQLite DB file. Defaults to backend/data/ if unset.
# In production (e.g. Railway), point this at a mounted persistent Volume so game
# history survives redeploys.
DB_DIR=
